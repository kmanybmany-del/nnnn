{
  "buildCommand": "pnpm install --no-frozen-lockfile && next build",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "env": {
    "PNPM_HOME": "/pnpm",
    "PATH": "$PNPM_HOME:$PATH"
  },
  "regions": ["iad1"],
  "functions": {
    "api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
